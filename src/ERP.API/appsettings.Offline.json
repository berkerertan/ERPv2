{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/stoknet-offline.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "SqlitePath": "data/stoknet-offline.db"
  },
  "Security": {
    "EnforceAuthorization": true
  },
  "TenantResolution": {
    "TenantCodeHeaderName": "X-Tenant-Code",
    "TenantIdHeaderName": "X-Tenant-Id",
    "DefaultTenantCode": "demo-tier3",
    "EnableDevelopmentFallback": true
  },
  "Cloudinary": {
    "Enabled": false
  },
  "AccountEmail": {
    "ProductName": "StokNet",
    "FrontendBaseUrl": "http://localhost:4200",
    "VerifyEmailPath": "/auth/verify-email"
  },
  "EmailVerification": {
    "TokenTtlHours": 24,
    "ResendCooldownSeconds": 90,
    "DailyResendLimit": 5,
    "EnforceVerifiedUsersForTenantRequests": true
  },
  "Gemini": {
    "Enabled": false,
    "ApiKey": ""
  },
  "Claude": {
    "Enabled": false,
    "ApiKey": ""
  }
}
