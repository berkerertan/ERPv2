{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/erpv2-offline.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "SqlitePath": "data/erpv2-offline.db"
  },
  "Security": {
    "EnforceAuthorization": true
  },
  "TenantResolution": {
    "TenantCodeHeaderName": "X-Tenant-Code",
    "TenantIdHeaderName": "X-Tenant-Id",
    "DefaultTenantCode": "demo-tier3",
    "EnableDevelopmentFallback": true
  },
  "Cloudinary": {
    "Enabled": false
  },
  "Gemini": {
    "Enabled": false,
    "ApiKey": ""
  },
  "Claude": {
    "Enabled": false,
    "ApiKey": ""
  }
}
