{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=ERPv2Db;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "ERPv2",
    "Audience": "ERPv2.Client",
    "Key": "ERPv2_Development_Key_Change_This_Immediately_12345",
    "AccessTokenMinutes": 60
  },
  "Security": {
    "EnforceAuthorization": true
  },
  "TenantResolution": {
    "TenantCodeHeaderName": "X-Tenant-Code",
    "TenantIdHeaderName": "X-Tenant-Id",
    "DefaultTenantCode": "demo-tier3",
    "EnableDevelopmentFallback": false
  },
  "Smtp": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "UserName": "",
    "Password": "",
    "FromEmail": "no-reply@erp.local",
    "FromName": "ERP Platform"
  },
  "EmailCampaign": {
    "Enabled": true,
    "PollIntervalSeconds": 15,
    "BatchSize": 100,
    "MaxAttempts": 3,
    "RetryDelayMinutes": 10
  },
  "Cloudinary": {
    "Enabled": false,
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "ProductImageFolder": "erpv2/products"
  },
  "AllowedHosts": "*"
}

