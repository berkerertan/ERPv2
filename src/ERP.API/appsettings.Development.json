  },
  "Gemini": {
    "Enabled": true,
    "ApiKey": "",
    "Model": "gemini-2.0-flash",
    "Endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
    "RequestTimeoutSeconds": 60
  },
  "Claude": {
    "Enabled": true,
    "ApiKey": "",
    "Model": "claude-sonnet-4-20250514",
    "MaxTokens": 4096,
