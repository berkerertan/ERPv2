{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "EnforceAuthorization": true
  },
  "TenantResolution": {
    "TenantCodeHeaderName": "X-Tenant-Code",
    "TenantIdHeaderName": "X-Tenant-Id",
    "DefaultTenantCode": "demo-tier3",
    "EnableDevelopmentFallback": true
  },
  "Smtp": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "UserName": "",
    "Password": "",
    "FromEmail": "no-reply@erp.local",
    "FromName": "ERP Platform"
  },
  "EmailCampaign": {
    "Enabled": true,
    "PollIntervalSeconds": 10,
    "BatchSize": 100,
    "MaxAttempts": 3,
    "RetryDelayMinutes": 5
  },
  "Cloudinary": {
    "Enabled": false,
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "ProductImageFolder": "erpv2/products"
  }
}
